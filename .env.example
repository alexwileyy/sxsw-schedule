# Supabase connection - copy this file to .env.local and fill in your project's values.
# Both are public client-side keys (safe to expose to the browser). Never put the
# service-role / secret key in a NEXT_PUBLIC_* variable.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
